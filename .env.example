# Postgres (operational source DB — runs in Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=beacon
POSTGRES_USER=beacon
POSTGRES_PASSWORD=beacon_secret

# MinIO (S3-compatible object storage — runs in Docker)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=beacon-bronze

# AWS SDK env vars — point at MinIO locally, real S3 in prod
AWS_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1

# DuckDB
DUCKDB_PATH=./data/beacon.duckdb

# Dagster
DAGSTER_HOME=./.dagster

# dlt pipeline settings
DLT_DATA_DIR=./data/dlt
BRONZE_BUCKET_URL=s3://beacon-bronze

# Great Expectations
GX_DATA_CONTEXT_ROOT_DIR=./quality

# FastAPI serving
SERVING_HOST=0.0.0.0
SERVING_PORT=8000
