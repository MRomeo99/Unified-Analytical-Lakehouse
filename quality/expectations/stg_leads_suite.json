{
  "expectation_suite_name": "stg_leads_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 17500, "max_value": 32500},
      "meta": {"notes": "500 clients × 35–65 leads each."}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "lead_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {"column": "lead_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "client_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "lead_source",
        "value_set": ["organic", "paid", "referral", "social"]
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "lead_status",
        "value_set": ["new", "contacted", "qualified", "converted", "lost"]
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "lead_value", "min_value": 0, "max_value": 10000},
      "meta": {}
    }
  ],
  "meta": {
    "great_expectations_version": "0.18.x"
  }
}
